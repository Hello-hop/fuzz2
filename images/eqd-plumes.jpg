<meta name="generator" content="Site Kit by Google 1.178.0" /><style class="wpcode-css-snippet">* ============================================   FUZZ & FRITURE — Masque header Kadence   sur la homepage uniquement   ============================================ */.home .site-header,.home header.site-header,.home #masthead {  display: none !important;}</style><script>(function() {
  'use strict';

  document.addEventListener('DOMContentLoaded', function() {

    // ── 1. FIX NEWSLETTER FORM sur la homepage ───────────────
    var nlForm = document.querySelector('.nl-form');
    if (nlForm) {
      var input  = nlForm.querySelector('.nl-input');
      var btn    = nlForm.querySelector('.nl-submit');

      if (input && btn && !nlForm.querySelector('form')) {
        // Créer le vrai formulaire
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = window.location.origin + '/';
        form.style.display = 'flex';
        form.style.flexDirection = 'column';
        form.style.gap = '12px';

        // Champ email renommé pour le handler PHP
        input.name = 'ff_newsletter_email';

        // Nonce (généré côté serveur via localized var ou data attr)
        var nonceInput = document.createElement('input');
        nonceInput.type = 'hidden';
        nonceInput.name = 'ff_nl_nonce';
        nonceInput.value = (window.ffNonce && window.ffNonce.nl) ? window.ffNonce.nl : '';

        // Bouton de type submit
        btn.type = 'submit';

        form.appendChild(nonceInput);
        form.appendChild(input);
        form.appendChild(btn);

        // Remplacer le contenu de .nl-form
        nlForm.innerHTML = '';
        nlForm.appendChild(form);
      }

      // Affichage message succès/erreur
      var params = new URLSearchParams(window.location.search);
      var nlStatus = params.get('nl');
      if (nlStatus) {
        var msg = document.createElement('div');
        msg.style.cssText = 'text-align:center;padding:12px;border-radius:6px;font-family:DM Mono,monospace;font-size:13px;margin-top:12px;';
        if (nlStatus === 'ok') {
          msg.style.background = 'rgba(201,69,0,0.15)';
          msg.style.color = '#C94500';
          msg.textContent = '✓ Merci ! Tu recevras nos bons plans chaque lundi.';
        } else {
          msg.style.background = 'rgba(255,0,0,0.1)';
          msg.style.color = '#ff6b6b';
          msg.textContent = '✗ Adresse e-mail invalide. Réessaie.';
        }
        var nlSection = document.querySelector('.newsletter');
        if (nlSection) nlSection.appendChild(msg);
      }
    }

    // ── 2. MESSAGE CONFIRMATION page contact ─────────────────
    if (window.location.pathname.includes('/contact')) {
      var sent = new URLSearchParams(window.location.search).get('sent');
      if (sent === '1') {
        var confirm = document.querySelector('.ff-contact-confirm');
        if (confirm) {
          confirm.style.display = 'block';
        }
      }
    }

  });
})();</script><link rel="icon" href="https://fuzz-et-friture.fr/wp-content/uploads/2026/04/favicon-96x96-1.png" sizes="32x32" />
